# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where quote requests are emailed to.
# One address, or several separated by commas: a@example.com, b@example.com
QUOTE_TO_EMAIL=jayanth.a@utexas.edu

# Sender address. Until you verify your own domain in Resend, use the sandbox:
#   onboarding@resend.dev
# Once your domain is verified, switch to e.g. quotes@platinumpressurewashing.pro
QUOTE_FROM_EMAIL=onboarding@resend.dev

# Pushover — optional phone notification on each quote (https://pushover.net).
# API token is the sender; USER_KEY is the recipient (one, or comma-separated).
# Set both to enable; leave blank to send email only.
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
